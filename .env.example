# ============================================================
#  Conan Exiles Shop Bot — environment template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ============================================================

# ── MariaDB ──────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=botuser
DB_PASS=changeme
DB_NAME=conanbotdb

# ── Conan Exiles Server ───────────────────────────────────────
# SERVER_NAME must match the prefix used for all per-server tables
SERVER_NAME=ConanExiles
RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASS=changeme
STEAM_QUERY_PORT=27015
GAME_DB_PATH=C:\Conan\ConanSandbox\Saved\game.db
GAME_LOG_PATH=C:\Conan\ConanSandbox\Saved\Logs\ConanSandbox.log

# ── Discord ───────────────────────────────────────────────────
DISCORD_TOKEN=your-bot-token-here
SERVERLOG_CHANNEL_ID=0
KILLLOG_CHANNEL_ID=0
ITEMS_FOR_SALE_CHANNEL_ID=0
SERVER_BUFFS_CHANNEL_ID=0
JAIL_CHANNEL_ID=0
EVENT_CHANNEL_ID=0
SOLO_LB_ALL_CHANNEL_ID=0
SOLO_LB_1D_CHANNEL_ID=0
SOLO_LB_7D_CHANNEL_ID=0
SOLO_LB_30D_CHANNEL_ID=0
CLAN_LB_ALL_CHANNEL_ID=0
CLAN_LB_1D_CHANNEL_ID=0
CLAN_LB_7D_CHANNEL_ID=0
CLAN_LB_30D_CHANNEL_ID=0
BUILDING_TRACKING_CHANNEL_ID=0
INVENTORY_TRACKING_CHANNEL_ID=0
WANTED_CHANNEL_ID=0
VAULT_RENTAL_CHANNEL_ID=0
# Channel for server settings change alerts (server_settings_watcher)
SERVER_SETTINGS_CHANNEL_ID=0

# ── Shop ──────────────────────────────────────────────────────
STARTING_CASH=100
PAYCHECK=50
PAYCHECK_INTERVAL_MINUTES=30
CURRENCY_NAME=coins

# ── Black Ice Converter ───────────────────────────────────────
# In-game template IDs (do not change unless you use a mod that remaps them)
BLACK_ICE_ITEM_ID=18040
HARDENED_BRICK_ITEM_ID=11142
# How many Black Ice = 1 Hardened Brick
BLACK_ICE_CONVERSION_RATE=10
# How often (seconds) the converter runs — default 120 = every 2 minutes
BLACK_ICE_CHECK_INTERVAL_SECONDS=120

# ── Prison (optional) ─────────────────────────────────────────
PRISON_ENABLED=False
PRISON_EXIT_COORDS=0 0 0
PRISON_MIN_X=0
PRISON_MAX_X=0
PRISON_MIN_Y=0
PRISON_MAX_Y=0

# ── Discord Role Names ────────────────────────────────────────
ADMIN_ROLE=Admin
MOD_ROLE=Moderator
VIP1_ROLE=VIP1
VIP2_ROLE=VIP2
VIP3_ROLE=VIP3
VIP4_ROLE=VIP4

# ── Timezone ──────────────────────────────────────────────────
# Offset in hours from UTC to match your server's log timestamps
TIMEZONE_OFFSET=-6

# ── Map URL (optional) ────────────────────────────────────────
# If set, a link button to your interactive server map is added
# to all leaderboard Discord embeds.
# Example: MAP_URL=https://map.yourserver.com
MAP_URL=

# ── Firewall Blocklist (optional) ─────────────────────────────
# Set FIREWALL_ENABLED=true to allow /addblock and /removeblock
# admin commands to apply OS-level firewall rules.
# Uses netsh on Windows, iptables on Linux.
FIREWALL_ENABLED=false
FIREWALL_BLOCKLIST_FILE=blocklist.txt

# -- Admin Bot Role (for /serverrestart) -----------------------
# Discord role required to execute /serverrestart. Defaults to
# AdminBot. Distinct from ADMIN_ROLE so you can limit who can
# bounce the game server without revoking general admin powers.
ADMINBOT_ROLE=AdminBot

# -- Raid Tracker (optional) -----------------------------------
# When /raidstart is used, raid_watcher polls building piece
# counts every RAID_CHECK_INTERVAL_SECONDS and posts an alert to
# RAID_ALERT_CHANNEL_ID whenever a clan loses
# RAID_ALERT_THRESHOLD or more pieces between checks. A per-clan
# cooldown of RAID_ALERT_COOLDOWN_SECONDS suppresses spam during
# long fights. Leave RAID_ALERT_CHANNEL_ID=0 to disable.
RAID_ALERT_CHANNEL_ID=0
RAID_ALERT_THRESHOLD=10
RAID_ALERT_COOLDOWN_SECONDS=60
RAID_CHECK_INTERVAL_SECONDS=10
# -- Scheduled Raid Window (optional) --------------------------
# When RAID_WINDOW_ENABLED=true, the raid tracker auto-opens
# every day between RAID_WINDOW_START and RAID_WINDOW_END (24h
# HH:MM in RAID_WINDOW_TZ). Manual /raidstart still works
# outside the window. Windows crossing midnight are supported
# (e.g. start=22:00 end=02:00).
RAID_WINDOW_ENABLED=false
RAID_WINDOW_START=18:00
RAID_WINDOW_END=22:00
RAID_WINDOW_TZ=America/New_York

# -- Rebuild-Under-Attack Detection ----------------------------
# During an active raid window, if a clan places new pieces
# within RAID_REBUILD_DAMAGE_LOOKBACK_SECONDS of taking damage,
# and the burst is at least RAID_REBUILD_MIN_PIECES, an embed
# is posted to SERVERLOG_CHANNEL_ID. Per-clan cooldown reuses
# RAID_ALERT_COOLDOWN_SECONDS.
RAID_REBUILD_DAMAGE_LOOKBACK_SECONDS=900
RAID_REBUILD_MIN_PIECES=1
# CSV of game_events.eventType values that count as building damage.
# Defaults match current Conan builds; bump if Funcom rotates IDs.
RAID_DAMAGE_EVENT_TYPES=172
# -- Shrine Tracker (optional) ---------------------------------
# When SHRINE_CHANNEL_ID is set, shrine_watcher polls game.db
# for placeables whose class matches SHRINE_CLASSES (CSV of full
# Blueprint paths) and maintains a pinned leaderboard embed in
# that channel showing the per-clan shrine count. Whenever a
# tracked shrine disappears from actor_position, a "Shrine
# Destroyed" embed is posted to the same channel, with the
# destroyer name pulled from destruction_history when available.
SHRINE_CHANNEL_ID=0
SHRINE_CLASSES=/Game/Systems/Building/Placeables/BP_PL_Altar_Yog_T3.BP_PL_Altar_Yog_T3_C
SHRINE_CHECK_INTERVAL_SECONDS=60
# -- Embed Timestamps ------------------------------------------
# When TIMESTAMP_FOOTER=true, every event embed adds a
# 'Server time: YYYY-MM-DD HH:MM:SS TZ' suffix to its footer so
# the host's wall-clock time is visible to every viewer regardless
# of their Discord locale. The native embed timestamp (rendered
# in each viewer's local TZ) is always set; this is purely
# additive for absolute clarity.
TIMESTAMP_FOOTER=false
# -- Kill Catch-Up ---------------------------------------------
# On every bot startup, replay any PvP kills that happened in
# game.db.game_events while the bot was offline so leaderboards
# stay accurate and the kill feed has no gaps. KILL_CATCHUP_MAX_REPLAY
# caps how many missed kills to post in one burst (re-run the bot
# to continue with the next batch). Set to 0 to disable.
KILL_CATCHUP_MAX_REPLAY=500
# -- Building Piece Filter -------------------------------------
# SQL LIKE pattern applied to building_instances.class when the
# bot materialises {sn}_building_piece_tracking. Filters out
# bombs, orbs, traps, banners, torches, bedrolls and other
# placeables that aren't real building pieces, so rebuild
# alerts and leaderboards reflect only structural pieces.
BUILDING_PIECE_CLASS_LIKE=%BP_Build%
# -- Game DB Watcher Interval ----------------------------------
# How often (seconds) the bot copies game.db state into MariaDB:
# per-clan piece counts, last_login, etc. Drives rebuild-during-
# raid detection and the building leaderboard. Default 60.
# Lower values make rebuild alerts snappier but only help if
# Conan's own ServerSaveInterval (ServerSettings.ini) is set
# equally low — otherwise game.db hasn't actually refreshed yet.
GAME_DB_WATCHER_INTERVAL_SECONDS=60
