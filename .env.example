# ============================================================
#  Conan Exiles Shop Bot — environment template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ============================================================

# ── MariaDB ──────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=botuser
DB_PASS=changeme
DB_NAME=conanbotdb

# ── Conan Exiles Server ───────────────────────────────────────
# SERVER_NAME must match the prefix used for all per-server tables
SERVER_NAME=ConanExiles
RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASS=changeme
STEAM_QUERY_PORT=27015
GAME_DB_PATH=C:\Conan\ConanSandbox\Saved\game.db
GAME_LOG_PATH=C:\Conan\ConanSandbox\Saved\Logs\ConanSandbox.log

# ── Discord ───────────────────────────────────────────────────
DISCORD_TOKEN=your-bot-token-here
SERVERLOG_CHANNEL_ID=0
KILLLOG_CHANNEL_ID=0
ITEMS_FOR_SALE_CHANNEL_ID=0
SERVER_BUFFS_CHANNEL_ID=0
JAIL_CHANNEL_ID=0
EVENT_CHANNEL_ID=0
SOLO_LB_ALL_CHANNEL_ID=0
SOLO_LB_1D_CHANNEL_ID=0
SOLO_LB_7D_CHANNEL_ID=0
SOLO_LB_30D_CHANNEL_ID=0
CLAN_LB_ALL_CHANNEL_ID=0
CLAN_LB_1D_CHANNEL_ID=0
CLAN_LB_7D_CHANNEL_ID=0
CLAN_LB_30D_CHANNEL_ID=0
BUILDING_TRACKING_CHANNEL_ID=0
INVENTORY_TRACKING_CHANNEL_ID=0
WANTED_CHANNEL_ID=0
VAULT_RENTAL_CHANNEL_ID=0
# Channel for server settings change alerts (server_settings_watcher)
SERVER_SETTINGS_CHANNEL_ID=0

# ── Shop ──────────────────────────────────────────────────────
STARTING_CASH=100
PAYCHECK=50
PAYCHECK_INTERVAL_MINUTES=30
CURRENCY_NAME=coins

# ── Black Ice Converter ───────────────────────────────────────
# In-game template IDs (do not change unless you use a mod that remaps them)
BLACK_ICE_ITEM_ID=18040
HARDENED_BRICK_ITEM_ID=11142
# How many Black Ice = 1 Hardened Brick
BLACK_ICE_CONVERSION_RATE=10
# How often (seconds) the converter runs — default 120 = every 2 minutes
BLACK_ICE_CHECK_INTERVAL_SECONDS=120

# ── Prison (optional) ─────────────────────────────────────────
PRISON_ENABLED=False
PRISON_EXIT_COORDS=0 0 0
PRISON_MIN_X=0
PRISON_MAX_X=0
PRISON_MIN_Y=0
PRISON_MAX_Y=0

# ── Discord Role Names ────────────────────────────────────────
ADMIN_ROLE=Admin
MOD_ROLE=Moderator
VIP1_ROLE=VIP1
VIP2_ROLE=VIP2
VIP3_ROLE=VIP3
VIP4_ROLE=VIP4

# ── Timezone ──────────────────────────────────────────────────
# Offset in hours from UTC to match your server's log timestamps
TIMEZONE_OFFSET=-6

# ── Map URL (optional) ────────────────────────────────────────
# If set, a link button to your interactive server map is added
# to all leaderboard Discord embeds.
# Example: MAP_URL=https://map.yourserver.com
MAP_URL=

# ── Firewall Blocklist (optional) ─────────────────────────────
# Set FIREWALL_ENABLED=true to allow /addblock and /removeblock
# admin commands to apply OS-level firewall rules.
# Uses netsh on Windows, iptables on Linux.
FIREWALL_ENABLED=false
FIREWALL_BLOCKLIST_FILE=blocklist.txt
